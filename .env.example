# ── Telegram ──
BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
# Public URL Render gives your service, e.g. https://ptexchange-bot.onrender.com
WEBHOOK_URL=https://your-app.onrender.com
# Any random long string - protects the webhook path from being guessed
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Database (Neon) ──
# Get this from the Neon dashboard - "Connection string" (pooled connection recommended)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/ptexchange?sslmode=require

# ── PTExchange gateways (unchanged from your existing setup) ──
TON_API_URL=https://ptexchange-api.vercel.app
BSC_API_URL=https://pt-kappa-ten.vercel.app
# ⚠️ ROTATE THIS - it was exposed in plaintext in the exported TPY code
GATEWAY_KEY=xunlock

# ⚠️ ROTATE THIS TOO - also exposed in plaintext (used for the toncenter.com jetton search)
TONCENTER_API_KEY=

# Shared secret your Vercel gateway sends in the x-webhook-secret header when
# it POSTs to /webhook/deposit. Generate any random string, e.g.:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEPOSIT_WEBHOOK_SECRET=

# ── Security ──
# 32-byte (64 hex chars) key for AES-256-GCM wallet encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ Losing this key makes every stored seed phrase unrecoverable. Back it up somewhere safe (NOT in git).
ENCRYPTION_KEY=

# ── Admin ──
BOT_ADMIN_ID=6011460052

# ── Optional: external keep-alive cron will hit GET /health ──
PORT=3000
